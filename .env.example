# =============================================================================
# AI-Assisted Security Research Dashboard — Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   Windows:   copy .env.example .env
#   macOS/Linux: cp .env.example .env
#
# All variables in this file are required. The app will crash on startup
# with a clear error message if any are missing.
# =============================================================================


# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------

# Required — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Optional — increases NVD CVE lookup rate limit from 5 to 50 req/30s
# Get one at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here


# -----------------------------------------------------------------------------
# Evaluator — Claude Haiku (cheap, fast triage)
#
# Every fetched article passes through this stage first. The model sees only
# the title and first ~1000 characters, then returns a score 0-100.
# Articles at or above EVAL_ACCEPT_THRESHOLD proceed to full summarization;
# articles below are filed as Low Priority.
# -----------------------------------------------------------------------------

# Articles scoring >= this threshold get the full Sonnet summarization treatment
EVAL_ACCEPT_THRESHOLD=55

# Persona sent as the system prompt — tells the model who it's working for
EVAL_SYSTEM_PROMPT="You are a security article triage agent. Score articles for technical depth on offensive security topics."

# Scoring rubric sent with each article — tune this to match your interests.
# {title} and {excerpt} are filled in automatically. Do not remove them.
# {{ and }} produce literal { } in the prompt (required for the JSON spec).
EVAL_USER_PROMPT="Score this security article on technical depth for an offensive security researcher.

Score 0-100 based on attack technique depth:
  90-100: Deep, specific TTPs with step-by-step technique detail
  70-89:  Rich technical content on attack mechanics
  40-69:  Partial technique depth
  0-39:   News, announcements, or shallow content

Return only valid JSON: {{\"score\": <0-100>, \"brief\": \"<10 words max>\"}}

<article_title>
{title}
</article_title>

<article_excerpt>
{excerpt}
</article_excerpt>"


# -----------------------------------------------------------------------------
# Summarizer — Claude Sonnet (deep analysis)
#
# Runs only on articles that passed the evaluator threshold. Receives up to
# 12,000 characters of article content and returns structured JSON used to
# populate the dashboard cards (summary, tooling, threat actors, CVEs, score).
# -----------------------------------------------------------------------------

# Persona sent as the system prompt
SUMMARIZER_SYSTEM_PROMPT="You are a security research analyst. Help practitioners understand how attacks work technically."

# Extraction prompt — the JSON schema here drives the dashboard card fields.
# {title} and {content} are filled in automatically. Do not remove them.
# Adjust the pt_relevance guide to match what you consider high-value content.
SUMMARIZER_USER_PROMPT="Analyze this security article and return a JSON object with exactly these fields:

{{
  \"summary\": \"3-5 sentences on the attack techniques and mechanics\",
  \"tooling\": [{{\"name\": \"tool name\", \"is_open_source\": true/false, \"purpose\": \"how it was used\"}}],
  \"threat_actors\": [\"named groups or malware families\"],
  \"cves\": [\"CVE IDs mentioned\"],
  \"pt_relevance\": <float 0.0-1.0, where 1.0=full attack lifecycle detail, 0.1=no technique depth>
}}

Return only valid JSON. No markdown.

<article_title>
{title}
</article_title>

<article_content>
{content}
</article_content>"


# -----------------------------------------------------------------------------
# Scorer — local math, no API calls
#
# Combines three signals into a final 0-100 ranking score.
# The three SCORER_WEIGHT_* values must sum to exactly 1.0.
#
#   pt_relevance — Sonnet's quality judgment from the summarizer
#   recency      — exponential decay based on article age
#   reputation   — per-source rating from sources.yaml (1-5 scale)
#
# SCORER_RECENCY_HALF_LIFE_DAYS controls how fast recency decays:
#   7  = aggressively prefer this week's content
#   14 = balanced (default)
#   30 = treat a month-old article nearly the same as today's
# -----------------------------------------------------------------------------

SCORER_WEIGHT_PT_RELEVANCE=0.5
SCORER_WEIGHT_RECENCY=0.3
SCORER_WEIGHT_REPUTATION=0.2

# Recency decay — controls how fast older articles lose score
SCORER_RECENCY_HALF_LIFE_DAYS=14.0
